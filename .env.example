# ========================================
# Prompt Generator Pro - Local Environment Template
# ========================================
# Copy this file to .env (local only) and fill in real values.
# .env is gitignored.
# ========================================

# Supabase values used by local node test scripts
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Local test account used by test-save.js
SUPABASE_TEST_EMAIL=your-test-email@example.com
SUPABASE_TEST_PASSWORD=your-test-password

# ========================================
# SECURITY NOTES
# ========================================
# 1. Never commit .env
# 2. Never commit real credentials in source files
# 3. Rotate test credentials if leaked
# ========================================
